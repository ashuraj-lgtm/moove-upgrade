  		  </li>
  		  <li class="nav-item second">
  		    <a class="nav-link active" id="pills-grid-tab" data-toggle="pill" href="#pills-grid" role="tab" aria-controls="pills-grid" aria-selected="true"><i class="fa fa-th" aria-hidden="true"></i></a>
  		  </li>
  	</ul>
  </div>

</div>

    <div class="row my-2">
        <div class="col-md ">
          <div class="studentinnerbox">
            <div class="inner">
              <h3>{{{coursesinprogress}}}</h3>
              <p>{{#str}}studentcourseinprogress, theme_moove{{/str}}</p>
            </div>
          </div>
        </div>
          <div class="col-md">
          <div class="studentinnerbox">
            <div class="inner">
