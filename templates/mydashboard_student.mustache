<div class="studentinfos">
<div class="d-flex justify-content-between">
  
  <div class="searchformcourse">
    <form id="searchform" action="/course/search.php" method="get">
        <div class="input-group">
            <div class="input-group-append">
                <div class="btn btn-outline-secondary"  id="button-addon2"><i class="fa fa-search"></i></div>
            </div>
            <input type="text" id="shortsearchbox" size="12" name="search" value="" class="form-control" placeholder=" {{#str}} searchbycourse, theme_moove {{/str}}" aria-label="Search" aria-describedby="button-addon2">
        </div>
    </form>
  </div>
  <div class="sortables">

  	<ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
