                          label: 'logins',
                          backgroundColor: 'rgb(255, 99, 132)',
                          borderColor: 'rgb(255, 99, 132)',
                          data: data.yearchart.data
                      }]
                  },
                  // Configuration options go here
                  options: {}
              });

                }

                },
                cache: false,
                contentType: false,
                processData: false 
            })
        }


    });

