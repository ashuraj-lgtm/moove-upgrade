<div id="progressoverview">
  <div class="row my-5 border-bottom">
    <div class="col-md-12">
      <div class="d-flex justify-content-between">
        {{# user}}
        <div class="profileinfo d-flex justify-content-between">
          <img src="{{profilepicture}}" alt="{{{firstname}}} {{{lastname}}}" class="userprofileimg border">
          <div class="info">
            <div>{{{firstname}}} {{{lastname}}}</div>
            <div>{{{email}}}</div>
          </div>
        </div>
        {{/ user}}
        <div class="exportbtn">
          <button class="btn btn-success rounded"> Export in excel </button>
        </div>
      </div>
    </div>
  </div>
      <div class="row my-2 px-5 text-center">
        <div class="col-md ">
          <div class="studentinnerbox border">
            <div class="inner">
              <h3>{{{coursesinprogress}}}</h3>
              <p>{{#str}}studentcourseinprogress, theme_moove{{/str}}</p>
            </div>
          </div>
        </div>
          <div class="col-md">
          <div class="studentinnerbox border">
            <div class="inner">
              <h3>{{{completedcourses}}}</h3>
              <p>{{#str}}studentcoursecompleted, theme_moove{{/str}}</p>
            </div>
          </div>
        </div>
          <div class="col-md">
          <div class="studentinnerbox border">
            <div class="inner">
              <h3>{{{totaltrainingtime}}}</h3>
              <p>{{#str}}studentcoursetrainingtime, theme_moove{{/str}}</p>
            </div>
          </div>
        </div>
          <div class="col-md">
          <div class="studentinnerbox border">
            <div class="inner">
              <h3>{{{badgescounts}}}</h3>
              <p>{{#str}}studentbadges, theme_moove{{/str}}</p>
            </div>
          </div>
        </div>
          <div class="col-md">
          <div class="studentinnerbox border">
            <div class="inner">
              <h3>{{{pointsearned}}}</h3>
              <p>{{#str}}studentgradepoints, theme_moove{{/str}}</p>
            </div>
          </div>
        </div>
        <div class="col-md-12 my-3">
          <div class="row">
            <div class="col-md-4">
                {{#overviewcourse}}
                  {{{overviewcourse}}}
                {{/overviewcourse}}
            </div>
            <div class="col-md-8">
              <p id="date_filter">
                  <span id="date-label-from" class="date-label">From: </span><input class="date_range_filter date" type="text" id="datepicker_from" />
                  <span id="date-label-to" class="date-label">To:<input class="date_range_filter date" type="text" id="datepicker_to" />
              </p>
            </div>
          </div>
        </div>
    </div>
    <div class="row my-3">
      <div class="col-md-9 border">
        <h4 class="h4"> Activity </h4>
        {{#userlastlogins}}
          <p class="text-muted"> {{lastweekaccess}} logins last week . {{lastmonthaccess}} logins last month . last login {{lastaccess}}</p>
        {{/userlastlogins}}
        <ul class="nav nav-tabs" id="activityline" role="tablist">
          <li class="nav-item">
            <a class="nav-link active" id="today-tab" data-toggle="tab" href="#today" role="tab" aria-controls="today" aria-selected="true">Today</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="yesterday-tab" data-toggle="tab" href="#yesterday" role="tab" aria-controls="yesterday" aria-selected="false">Yesterday</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="week-tab" data-toggle="tab" href="#week" role="tab" aria-controls="week" aria-selected="false">week</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="month-tab" data-toggle="tab" href="#month" role="tab" aria-controls="month" aria-selected="false">month</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="year-tab" data-toggle="tab" href="#year" role="tab" aria-controls="year" aria-selected="false">year</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="period-tab" data-toggle="tab" href="#period" role="tab" aria-controls="period" aria-selected="false">period</a>
          </li>
        </ul>
        <div class="tab-content" id="activitylineContent">
          <div class="tab-pane fade show active" id="today" role="tabpanel" aria-labelledby="today-tab"> Today
            <canvas id="todaychart"></canvas>
           </div>
          <div class="tab-pane fade" id="yesterday" role="tabpanel" aria-labelledby="yesterday-tab">
          <canvas id="yesterdaychart"></canvas>
          </div>
          <div class="tab-pane fade" id="week" role="tabpanel" aria-labelledby="week-tab">
          <canvas id="weekchart"></canvas>
          </div>
          <div class="tab-pane fade" id="month" role="tabpanel" aria-labelledby="month-tab">
          <canvas id="monthchart"></canvas>
          </div>
          <div class="tab-pane fade" id="year" role="tabpanel" aria-labelledby="year-tab">
          <canvas id="yearchart"></canvas>
          </div>
          <div class="tab-pane fade" id="period" role="tabpanel" aria-labelledby="period-tab">period</div>
        </div>
      </div>
      <div class="col-md-3 border">
        <h4 class="h4"> Progress overview </h4>
       <canvas id="Progressoverview"></canvas>
      </div>
      <div class="col-md-9 border">
        <div class="recently-content">
          <span> Recently earned badges </span>
          <a href="#">View all badges </a>
          <div class="circle">
            <div class="circle_content">
            <span><b id="badgescountsid"> </b></span>
            <span class="earnedtext"><b>You have earned</b></span>
            <p><b>Don't give up</b></p>
          </div>
        </div>
        </div>
      </div>
      <div class="col-md-3 border">
        <span> compared to others </span>
        <div class="points">
          <div class="points_1"> </div>
          <div class="points_1"></div>
          <div class="points_1"></div>
        </div>
      </div>
    </div>
</div>

{{#js}}

require(['jquery',  'mychartjs'], function($) {
  
  if($('#coursesoverview').has('option').length > 0){
   var e = document.getElementById("coursesoverview");
   var courseid = e.options[e.selectedIndex].value;
   console.log("courseid", courseid);
  }else{
  var courseid = "";
}


    $('#coursesoverview').on('change', function() {
      var courseid = this.value;
      console.log("courseid", courseid);

        var form_data = new FormData();
      form_data.append('courseid', courseid);
              if (courseid) {   
            $.ajax({ 
                type: 'POST',
                url: '{{config.wwwroot}}/theme/moove/chartprogress.php',
                data: form_data, 
                success:function(data){
                  console.log("data", JSON.parse(data));
                var data =  JSON.parse(data);

              if(typeof data.badge_issued_count !== "undefined" ){
                $("#badgescountsid").text(data.badge_issued_count);
              }

              
              if(typeof data.coursepercentage !== "undefined" ){
                var Progressoverview_ctx = document.getElementById('Progressoverview').getContext('2d');
                  var chartProgressoverview_ctx = new Chart(Progressoverview_ctx, {
                  type: 'doughnut',
                  // The data for our dataset

                  data: {
                      labels: ['course progress'],
                      datasets: [{
                          label: ['couse progress', 'to completed'],
                          backgroundColor: ['rgb(0,80,130)', '(152,223,238)'],
                          borderColor: ['rgb(0,80,130)', '(152,223,238)'],
                          data: [data.coursepercentage, 100-data.coursepercentage]
                      }]
                  },
                  // Configuration options go here
                  options: {
                    tooltips: {
                         enabled: false
                    },
                    cutoutPercentage: 70
                  }
              });

                  Chart.pluginService.register({
                    beforeDraw: function(chart) {
                      var width = chart.chart.width,
                          height = chart.chart.height,
                          ctx = chart.chart.ctx;
                            ctx.restore();
                          if (ctx.canvas.id == "Progressoverview") {
                            var fontSize = (height / 114).toFixed(2);
                            ctx.font = fontSize + "em sans-serif";
                            ctx.textBaseline = "middle";

                            var text =  data.coursepercentage+"%",
                                textX = Math.round((width - ctx.measureText(text).width) / 2),
                                textY = height / 2;

                            ctx.fillText(text, textX, textY);
                            ctx.save();   
                          }
                    }
                  });
              }

                if (data.todaychart) {
                  var todaychart_ctx = document.getElementById('todaychart').getContext('2d');
                  var charttodaychart_ctx = new Chart(todaychart_ctx, {
                  type: 'line',
                  // The data for our dataset
                  data: {
                      labels: data.todaychart.labels,
                      datasets: [{
                          label: 'logins',
                          backgroundColor: 'rgb(255, 99, 132)',
                          borderColor: 'rgb(255, 99, 132)',
                          data: data.todaychart.data
                      }]
                  },
