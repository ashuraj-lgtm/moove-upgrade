                      labels: data.monthchart.labels,
                      datasets: [{
                          label: 'logins',
                          backgroundColor: 'rgb(255, 99, 132)',
                          borderColor: 'rgb(255, 99, 132)',
                          data: data.monthchart.data
                      }]
                  },
                  // Configuration options go here
                  options: {}
              });

                }
                if (data.weekchart) {
                  var weekchart_ctx = document.getElementById('weekchart').getContext('2d');
                  var chartweekchart_ctx = new Chart(weekchart_ctx, {
                  type: 'line',
                  // The data for our dataset
                  data: {
                      labels: data.weekchart.labels,
                      datasets: [{
                          label: 'logins',
                          backgroundColor: 'rgb(255, 99, 132)',
                          borderColor: 'rgb(255, 99, 132)',
                          data: data.weekchart.data
                      }]
                  },
                  // Configuration options go here
                  options: {}
              });

                }
                if (data.yearchart) {
                  var yearchart_ctx = document.getElementById('yearchart').getContext('2d');
                  var chartyearchart_ctx = new Chart(yearchart_ctx, {
                  type: 'line',
                  // The data for our dataset
