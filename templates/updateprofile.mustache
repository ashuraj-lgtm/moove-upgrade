<div class="card-body">
    
    <form class="update-user-form p-3" action="#" method="POST" role="form" id="updateprofileform">
        {{# user}}
            <div class="row">
                <div class="col-md-2 offset-5">
                    <label for="userprofileimage">
                <div class="profilepic text-center rounded round my-5">
                   <img src="{{profilepicture}}" alt="{{{firstname}}} {{{lastname}}}" id="outImage">
                   <i class="fa fa-plus-circle" aria-hidden="true"></i>
                </div>
            </label>
            <input type="file" name="userprofileimage" accept='image/*' id="userprofileimage">
                 </div>
            </div>
        
        <div class="form-group row">
            <div class="col-md-4">
                <label for="name"> {{#str}}updatename, theme_moove{{/str}} </label>
            </div>
            <div class="col-md-8">
                <div class="d-flex">
                    <input type="text" name="firstname" id="firstname" class="form-control" value="{{{firstname}}} ">
                    <input type="text" name="lastname" id="lastname" class="form-control" value="{{{lastname}}}">    
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-4">
                 <label for="emailaddress">{{#str}}updateemail, theme_moove{{/str}}</label>
            </div>
            <div class="col-md-8">   
                <input type="email" name="emailaddress" id="emailaddress" class="form-control" value="{{{email}}}">    
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-4">
                <label for="username">{{#str}}updateusername, theme_moove{{/str}}</label>
            </div>
            <div class="col-md-8"> 
                <input type="text" name="username" id="username" class="form-control" value="{{{username}}}">    
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-4">
                <label for="password">{{#str}}updatepassword, theme_moove{{/str}}</label>
            </div>
            <div class="col-md-8">
                <input type="password" name="password" id="password" class="form-control" placeholder="{{#str}}placeholderpassword, theme_moove{{/str}}">    
            </div>
        </div>
       <div class="form-group row">
            <div class="col-md-4">
                <label for="bio">{{#str}}updatebio, theme_moove{{/str}}</label>
            </div>
            <div class="col-md-8">
                <textarea class="form-control" id="bio" name="bio">{{{description}}}</textarea>    
            </div>
        </div>
        <div class="update-user d-flex justify-content-center">
            <button type="submit" class="btn btn-success rounded mx-3">{{#str}}updatemainbuttom, theme_moove{{/str}}</button>
            <button type="button" class="btn btn-success rounded mx-3">{{#str}}updatecancelbtn, theme_moove{{/str}}</button>
        </div>
        {{/ user}}
    </form>
</div>
{{#js}}
require(['jquery', 'core/modal_factory'], function($, ModalFactory) {
    $('#userprofileimage').change(function(e){
        var filename = $('#userprofileimage').val().split('\\').pop();
        // $('#filelabelimage .filetext').contents().eq(0).replaceWith(filename);
        console.log("filename", filename);
    });


    $('#updateprofileform').submit(function (e) {
        e.preventDefault();
        var submitform = false;
        var timeout = 2000;
        var userprofileimage = $('#userprofileimage').prop('files')[0];   

        var firstname = $('#firstname').val();
        var lastname = $('#lastname').val(); 
        var emailaddress = $('#emailaddress').val();
        var username = $('#username').val();
        var bio = $('#bio').val();
        var password = $('#password').val();
        var form_data = new FormData();

        form_data.append('file', userprofileimage);
        form_data.append('firstname', firstname);
        form_data.append('lastname', lastname);
        form_data.append('emailaddress', emailaddress);
        form_data.append('username', username);
        form_data.append('bio', bio);
        form_data.append('password', password);    
            
        if (emailaddress !=="" &&  firstname !== "" && typeof emailaddress !== "undefined" && typeof firstname !== "undefined" ) {
            submitform = true;
        }
        if (submitform) {   
            $.ajax({ 
                type: 'POST',
                url: '{{config.wwwroot}}/theme/moove/updateprofile.php',
                data: form_data, 
                success:function(data){
                    if (data) {
                        var data = JSON.parse(data);
                        if (data.error !== null) {
                        var trigger = $('#updateuserdetails');
                        ModalFactory.create({
                            title: '',
                            body: '<p class="updateusermessage">'+data.message+'</p>',
                            footer: '',
                          }, trigger)
                          .then(function(modal) {
                            modal.show();
                            setTimeout(
                                  function() 
                                  {
                                  location.reload();
                                  }, 2000);
                                    
                                    
                        })
                         .done(function(modal) {
                            // Do what you want with your new modal.
                         });
                        }
                    }
                },
                cache: false,
                contentType: false,
                processData: false 
            })
        }
    });

});

{{/js}}
