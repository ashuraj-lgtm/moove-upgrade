<div class="modal fade" id="fileviewmodal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body">
                <div class="modaladdthml" id="modaladdthml" ></div> 
            </div>
        </div>
    </div>
</div>
<table id="userfilestable" class="display" style="width:100%">
        <thead>
            <tr>
            	<th>S.No.</th>
                <th>Name</th>
                <th>Type</th>
                <th>Size</th>
                <th>Uploaded </th>
                <th>Options</th>
            </tr>
        </thead>
        <tbody>
            {{#userfiles}}
            <tr>
            	<td></td>
                <td>{{filename}}</td>
                <td>{{fileextension}}</td>
                <td>{{filesize}}</td>
                <td>{{filecreated}}</td>
                <td>
                    <div class="d-flex text-primary text-center my-1">
                        <a  data-url="{{fileurl}}" data-type="{{fileextension}}" class="p-1 fileviewcontent"> <i class="fa fa-eye" aria-hidden="true"></i> </a>
                        <a href="{{fileurl}}" class="p-1"> <i class="fa fa-download" aria-hidden="true"></i> </a>
                    </div>
                </td>
            </tr>
            {{/userfiles}}
            {{^userfiles}}
            <tr>
                <td> No  </td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
            {{/userfiles}}
        </tbody>
    </table>


{{#js}}
require(['jquery','jqueryui','datatables'], function($) {
    var t = $('#userfilestable').DataTable( {
        "columnDefs": [ {
            "searchable": false,
            "orderable": false,
            "targets": 0
        } ],
        "order": [[ 1, 'asc' ]]
    } );
 
    t.on( 'order.dt search.dt', function () {
        t.column(0, {search:'applied', order:'applied'}).nodes().each( function (cell, i) {
            cell.innerHTML = i+1;
        } );
    } ).draw();

$('.fileviewcontent').on('click', function(e) {
    var imagefileextension = ["jpg", "jpeg", "bmp", "gif", "png"]; 
    sourceurl = $(this).data("url");
    sourcetype = $(this).data("type");
    console.log("sourceurl", sourceurl);
    console.log("sourcetype", sourcetype);

    if (imagefileextension.includes(sourcetype)) {
       var imagehtml = "<img src='"+sourceurl+"' class='img-fluid'>";
        $("#modaladdthml").html(imagehtml);
        console.log("imagehtml", imagehtml);
    $('#fileviewmodal').modal('show');
    }
 });


    return {};
});

{{/js}}
