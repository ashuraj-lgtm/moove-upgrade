<table id="courseprogress" class="display" style="width:100%">
        <thead>
            <tr>
            	<th>S.No.</th>
                <th>Course name </th>
                <th>Progress </th>
                <th>Score </th>
                <th>Enrolled on </th>
                <th>Completion on</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody>
            {{#progresscourses}}
            <tr>
            	<td></td>
                <td>{{fullname}}</td>
                <td>{{progress}}</td>
                <td>{{score}}</td>
                <td>{{#enrolltime}} {{#userdate}} {{enrolltime}}, %m/%d/%Y {{/userdate}} {{/enrolltime}}</td>
                <td>{{#enddate }} {{#userdate}} {{enddate}}, %m/%d/%Y {{/userdate}} {{/enddate }}  </td>
                <td>{{time}}</td>
            </tr>
            {{/progresscourses}}
            {{^progresscourses}}
            <tr>
                <p class="text-center"> Not enrolled in course </p>
            </tr>
            {{/progresscourses}}
        </tbody>
    </table>


{{#js}}
require(['jquery','jqueryui','datatables'], function($) {
    var t = $('#courseprogress').DataTable( {
        "columnDefs": [ {
            "searchable": false,
            "orderable": false,
            "targets": 0
        } ],
        "order": [[ 1, 'asc' ]]
    } );
 
    t.on( 'order.dt search.dt', function () {
        t.column(0, {search:'applied', order:'applied'}).nodes().each( function (cell, i) {
            cell.innerHTML = i+1;
        } );
    } ).draw();


    
    return {};
});

{{/js}}




